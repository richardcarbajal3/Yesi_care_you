# Base de datos PostgreSQL (requerida)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Secreto para sesiones Express (requerido en producción)
SESSION_SECRET=genera-un-secreto-seguro-aqui

# OpenAI API (requerida para mensajes de Yesi)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Puerto del servidor (Railway lo asigna automáticamente)
# PORT=5000
